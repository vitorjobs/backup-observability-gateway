OBSERVABILITY_STACK_NAME=veeam-one-monitoring
OBSERVABILITY_NETWORK_NAME=veeam-one-observability
OBSERVABILITY_ENVIRONMENT=local

API_IMAGE=backup-observability-gateway-v2:latest
API_CONTAINER_NAME=veeam-one-api
API_RESTART_POLICY=unless-stopped
API_HOST_PORT=9469

PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_CONTAINER_NAME=veeam-one-prometheus
PROMETHEUS_RESTART_POLICY=unless-stopped
PROMETHEUS_HOST_PORT=19090
PROMETHEUS_VOLUME_NAME=veeam-one-monitoring-prometheus-data

GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_CONTAINER_NAME=veeam-one-grafana
GRAFANA_RESTART_POLICY=unless-stopped
GRAFANA_HOST_PORT=13000
GRAFANA_VOLUME_NAME=veeam-one-monitoring-grafana-data
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

VITEPRESS_IMAGE=backup-observability-gateway-vitepress:latest
VITEPRESS_CONTAINER_NAME=veeam-one-vitepress
VITEPRESS_RESTART_POLICY=unless-stopped
VITEPRESS_HOST_PORT=4173
