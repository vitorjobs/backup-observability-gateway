{
  "name": "backup-observability-gateway",
  "version": "0.1.0",
  "description": "Gateway Node.js/TypeScript para observabilidade de plataformas de backup via APIs REST e metricas Prometheus.",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "check": "tsc --noEmit -p tsconfig.test.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.18.1",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "prom-client": "^15.1.3"
  }
}
